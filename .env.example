OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APP_SITE_URL=http://localhost:5173
APP_NAME=ArC Safety Evaluator
# Optional: 1 API call per model (JUSTIFY only). Skips stability + per-reason sufficiency.
# ARC_FAST_EVAL=1
# Optional: evaluate models one after another (helps stay under ~20 req/min on :free).
# ARC_EVAL_SEQUENTIAL=1
# Seconds between LLM calls in the full pipeline (default 1.0). Try 0.5 for speed if you rarely 429.
# ARC_INTER_CALL_DELAY=1.0
# Max parallel OpenRouter POSTs across all models (default 2). Use 1 if you still see frequent 429.
# OPENROUTER_MAX_CONCURRENT=2
