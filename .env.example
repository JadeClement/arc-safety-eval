OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APP_SITE_URL=http://localhost:5173
APP_NAME=ArC Safety Evaluator
# Optional: 1 API call per model (JUSTIFY only). Skips stability + per-reason sufficiency.
# ARC_FAST_EVAL=1
# Optional: evaluate models one after another (helps stay under ~20 req/min on :free).
# ARC_EVAL_SEQUENTIAL=1
# Seconds between finishing one model and starting the next when sequential (default 15). Raise if Step 4 still 429s.
# INTER_MODEL_DELAY=25
# Seconds between LLM calls in the full pipeline (default 1.0). On :free try 2–4 if Step 4 fails mid-run.
# ARC_INTER_CALL_DELAY=2.0
# Max parallel OpenRouter POSTs across all models (default 2). Use 1 if you still see frequent 429.
# OPENROUTER_MAX_CONCURRENT=1
# Comma-separated wait seconds between 429 retries when Retry-After is missing (default 45,90,180,240).
# Add more numbers for extra attempts, e.g. OPENROUTER_429_BACKOFF_S=60,120,180,240,300
# OPENROUTER_429_BACKOFF_S=
# Max characters per dataset sample row in API/UI (default 12000). Set 0 for no truncation.
# DATASET_SAMPLE_MAX_CHARS=12000
# Optional: path to your own rationales JSON (default backend/data/human_rationales.json).
# HUMAN_RATIONALES_PATH=/absolute/path/to/rationales.json
# Optional: compare judge for Step 6 (default Llama 3.3 70B — same class as graph judge, most reliable).
# GRAPH_COMPARE_JUDGE_MODEL_ID=meta-llama/llama-3.3-70b-instruct
